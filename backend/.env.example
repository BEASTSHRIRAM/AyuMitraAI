# MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=ayumitra

# JWT (required - generate a strong random secret, e.g. `openssl rand -hex 32`)
JWT_SECRET_KEY=change-me-to-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=10080

# Google Gemini
GOOGLE_API_KEY=your-google-api-key
GOOGLE_GEMINI_API_KEY=your-google-gemini-api-key

# Cerebras AI (used by cerebras_service.py)
CEREBRAS_API_KEY=your-cerebras-api-key

# LangSmith Tracing
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=ayumitra-ai
LANGSMITH_TRACING=true
LANGCHAIN_TRACING_V2=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# Firecrawl Web Scraping
FIRECRAWL_API_KEY=your-firecrawl-api-key

# Maps
MAPPLES_API_KEY=your-mapples-api-key

# CORS (comma-separated origins; do NOT use * in production)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
